{
  "name": "overlay-browser-for-your-favorite-llm",
  "version": "0.2.0",
  "description": "Overlay browser PoC with global shortcut and profile persistence (Electron)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.fajarnadril.overlaybrowser",
    "productName": "OverlayBrowser",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "portable": {
      "requestExecutionLevel": "user"
    },
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!*.md",
      "!*.bat",
      "!*.ps1",
      "!README*",
      "chaticon.svg"
    ]
  },
  "devDependencies": {
    "electron": "^26.1.0",
    "electron-builder": "^24.13.3"
  },
  "author": "",
  "license": "MIT"
}